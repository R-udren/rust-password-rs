---
import { Download } from '@lucide/astro';
import { translations, type Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const t = translations[lang];
---
<section class="download page"><div class="glow" aria-hidden="true"></div><p class="label">{t.getStarted}</p><h2>{t.downloadHeading}<br />{t.downloadHeadingAccent}</h2><p class="summary">{t.heroDescription}</p><a class="primary-button" href="https://github.com/R-udren/rust-password-rs/releases/latest/download/rust-password.exe"><Download size={16} />{t.download}</a></section>
<style>
  .download { position: relative; overflow: hidden; padding: 190px clamp(24px,6vw,76px) 205px; text-align: center; }
  .glow { position: absolute; z-index: -1; top: 24%; left: 50%; width: min(960px,120vw); height: 360px; border-radius: 50%; background: rgba(79,58,115,.13); filter: blur(95px); transform: translateX(-50%); }
  h2 { max-width: 900px; margin: 1.65rem auto 1.45rem; font-size: clamp(2.7rem,6vw,5.5rem); font-weight: 520; letter-spacing: -.06em; line-height: 1.04; }
  .summary { max-width: 620px; margin: 0 auto 2.35rem; color: #aaa6b0; font-size: 1rem; line-height: 1.8; }
  @media (max-width: 600px) { .download { padding-block: 145px 160px; } h2 { margin-top: 1.4rem; } }
</style>
