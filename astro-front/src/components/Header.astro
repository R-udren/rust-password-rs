---
import { Image } from 'astro:assets';
import iconImg from '../assets/icon.png';
import { translations, type Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const t = translations[lang];
const base = import.meta.env.BASE_URL;
const otherLang = lang === 'en' ? 'ru' : 'en';
const homePath = lang === 'en' ? base : `${base}ru/`;
const otherPath = lang === 'en' ? `${base}ru/` : base;
---
<header class="header">
  <nav class="nav page" aria-label="Main navigation">
    <a class="brand" href={homePath}><Image src={iconImg} alt="" width={24} height={24} /><span>{t.title}</span></a>
    <div class="links"><a href="#features">{t.features}</a><a href="#privacy">{t.privacy}</a><a href="https://github.com/R-udren/rust-password-rs" target="_blank" rel="noopener noreferrer">GitHub</a></div>
    <div class="actions"><a class="language" href={otherPath} onclick={`localStorage.setItem('lang','${otherLang}')`}>{t.language}</a><a class="download" href="https://github.com/R-udren/rust-password-rs/releases/latest/download/rust-password.exe">{t.download}</a></div>
  </nav>
</header>
<style>
  .header { position: absolute; z-index: 10; top: 16px; width: 100%; }
  .nav { display: grid; grid-template-columns: 1fr auto 1fr; min-height: 58px; align-items: center; padding: 0 13px 0 16px; border: 1px solid var(--border); border-radius: 12px; background: rgba(7,7,9,.78); box-shadow: 0 14px 44px rgba(0,0,0,.25); backdrop-filter: blur(18px); }
  .brand,.links,.actions { display: flex; align-items: center; }
  .brand { gap: .65rem; font-size: .9rem; font-weight: 650; }
  .brand :global(img) { border-radius: 5px; }
  .links { gap: 1.8rem; color: #8c8992; font-size: .84rem; }
  .actions { justify-content: end; gap: 1.1rem; color: #96929c; font-size: .84rem; }
  .links a,.language { transition: color 150ms ease; }.links a:hover,.language:hover { color: var(--text); }
  .download { padding: .55rem .75rem; border: 1px solid #cbc9ce; border-radius: 7px; color: #111114; background: #e6e5e8; font-weight: 600; }
  @media (max-width: 760px) { .nav { grid-template-columns: 1fr auto; }.links { display: none; }.language { display: none; } }
</style>
