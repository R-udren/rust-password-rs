---
import { translations, type Locale } from '../i18n/translations';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const t = translations[lang];
---
<footer><div class="page inner"><p>{t.footerText} <span>.insoulglobal</span></p><div><a href="https://github.com/R-udren/rust-password-rs" target="_blank" rel="noopener noreferrer">GitHub ↗</a><a href="#">Back to top ↑</a></div></div></footer>
<style>
  footer { border-top: 1px solid var(--border); }.inner { display: flex; min-height: 88px; align-items: center; justify-content: space-between; color: #55535a; font-size: .72rem; }.inner div { display: flex; gap: 1.4rem; }span,a:hover { color: #929097; }
  @media (max-width: 480px) { .inner { align-items: flex-start; flex-direction: column; justify-content: center; gap: .6rem; }p { margin: 0; } }
</style>
