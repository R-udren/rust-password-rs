---
import { Download } from 'lucide-astro';
import { translations, type Locale } from '../i18n/translations';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = translations[lang];
const base = import.meta.env.BASE_URL;
---

<section class="flex min-h-[80vh] flex-col items-center justify-center px-6 pt-24 text-center">
  <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-1.5 text-sm text-[var(--color-text-muted)]">
    <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
    v0.2.0 — Windows
  </div>

  <h1 class="mb-4 max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl lg:text-6xl">
    {t.title}
  </h1>

  <p class="mb-8 max-w-2xl text-lg text-[var(--color-text-muted)] sm:text-xl">
    {t.tagline}
  </p>

  <div class="flex flex-col items-center gap-3">
    <a
      href="https://github.com/R-udren/rust-password-rs/releases/latest/download/RustPassword.exe"
      class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-accent)] px-6 py-3 text-base font-semibold text-white transition-all hover:bg-[var(--color-accent-hover)] hover:shadow-lg hover:shadow-orange-500/20"
    >
      <Download class="h-5 w-5" />
      {t.download}
    </a>
    <span class="text-sm text-[var(--color-text-muted)]">{t.downloadSubtext}</span>
  </div>

  <div class="mt-12 w-full max-w-4xl overflow-hidden rounded-xl border border-[var(--color-border)] shadow-2xl shadow-black/50">
    <img
      src={`${base}preview.png`}
      alt="Rust Password app preview"
      class="w-full"
      loading="eager"
    />
  </div>
</section>
